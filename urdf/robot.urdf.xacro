<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="sensor_robot">

  <!-- ==================== PROPERTIES ==================== -->
  <xacro:property name="body_length" value="1.0"/>
  <xacro:property name="body_width"  value="0.6"/>
  <xacro:property name="body_height" value="0.4"/>

  <xacro:property name="wheel_radius" value="0.1"/>
  <xacro:property name="wheel_width"  value="0.05"/>

  <!-- ==================== BASE LINK ==================== -->
  <link name="base_link">
    <visual>
      <geometry>
        <box size="${body_length} ${body_width} ${body_height}"/>
      </geometry>
      <material name="blue">
        <color rgba="0.0 0.0 0.8 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <box size="${body_length} ${body_width} ${body_height}"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="10.0"/>
      <inertia ixx="0.1" ixy="0.0" ixz="0.0"
               iyy="0.1" iyz="0.0" izz="0.1"/>
    </inertial>
  </link>

  <!-- ==================== WHEEL MACRO ==================== -->
  <xacro:macro name="wheel" params="name x y">
    <link name="${name}_wheel">
      <visual>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
        <material name="black">
          <color rgba="0.1 0.1 0.1 1.0"/>
        </material>
      </visual>
      <collision>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
      </collision>
      <inertial>
        <mass value="1.0"/>
        <inertia ixx="0.01" ixy="0.0" ixz="0.0"
                 iyy="0.01" iyz="0.0" izz="0.01"/>
      </inertial>
    </link>

    <joint name="${name}_wheel_joint" type="continuous">
      <parent link="base_link"/>
      <child link="${name}_wheel"/>
      <origin xyz="${x} ${y} -0.1" rpy="1.5708 0 0"/>
      <axis xyz="0 0 1"/>
    </joint>
  </xacro:macro>

  <!-- 4 Wheels -->
  <xacro:wheel name="front_left"  x=" 0.4" y=" 0.35"/>
  <xacro:wheel name="front_right" x=" 0.4" y="-0.35"/>
  <xacro:wheel name="rear_left"   x="-0.4" y=" 0.35"/>
  <xacro:wheel name="rear_right"  x="-0.4" y="-0.35"/>

  <!-- ==================== FRONT CAMERA ==================== -->
  <link name="front_camera">
    <visual>
      <geometry>
        <box size="0.05 0.1 0.05"/>
      </geometry>
      <material name="red">
        <color rgba="0.8 0.0 0.0 1.0"/>
      </material>
    </visual>
  </link>

  <joint name="front_camera_joint" type="fixed">
    <parent link="base_link"/>
    <child link="front_camera"/>
    <origin xyz="0.525 0.0 0.0" rpy="0 0 0"/>
  </joint>

  <!-- ==================== BACK CAMERA ==================== -->
  <link name="back_camera">
    <visual>
      <geometry>
        <box size="0.05 0.1 0.05"/>
      </geometry>
      <material name="red">
        <color rgba="0.8 0.0 0.0 1.0"/>
      </material>
    </visual>
  </link>

  <joint name="back_camera_joint" type="fixed">
    <parent link="base_link"/>
    <child link="back_camera"/>
    <origin xyz="-0.525 0.0 0.0" rpy="0 0 3.1416"/>
  </joint>

  <!-- ==================== LIDAR ==================== -->
  <link name="lidar">
    <visual>
      <geometry>
        <cylinder radius="0.05" length="0.08"/>
      </geometry>
      <material name="green">
        <color rgba="0.0 0.8 0.0 1.0"/>
      </material>
    </visual>
  </link>

  <joint name="lidar_joint" type="fixed">
    <parent link="base_link"/>
    <child link="lidar"/>
    <origin xyz="0.0 0.0 0.24" rpy="0 0 0"/>
  </joint>

</robot>